# Copy this file to .env.local and fill in your values.

# Supabase — from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SimFin — from https://app.simfin.com (Account > API). Server-side only, never exposed to the client.
SIMFIN_API_KEY=your-simfin-api-key

# Anthropic — for the Scout (AI search) module. Server-side only.
ANTHROPIC_API_KEY=your-anthropic-api-key
