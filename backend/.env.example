# SEC requires a descriptive User-Agent including a contact email (see sec.gov fair-access policy)
SEC_USER_AGENT=FinClone/0.1 (mohsin@boegroup.com)

# SQLite for dev; use postgresql+psycopg://user:pass@host/dbname in production
DATABASE_URL=sqlite:///./finclone.db

# DeepSeek API key for the LLM-based KPI extractor and Scout (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model for KPI extraction (deepseek-chat or deepseek-reasoner)
FINCLONE_KPI_MODEL=deepseek-chat

# Cost control: max document chunks sent to the LLM per filing
FINCLONE_KPI_MAX_CHUNKS=6

# SimFin — cross-reference validation source (PDR §3)
SIMFIN_API_KEY=your-simfin-key

# Supabase Storage — raw-filing archive (fills the PDR's S3 role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
FINCLONE_ARCHIVE_BUCKET=filings

# API key enforcement (PDR Module 5)
FINCLONE_REQUIRE_API_KEY=false
FINCLONE_ADMIN_TOKEN=set-a-long-random-admin-token

# Flag values whose SEC vs reference variance exceeds this fraction (PDR: 1%)
FINCLONE_VARIANCE_THRESHOLD=0.01
